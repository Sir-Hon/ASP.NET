@page "/"

<PageTitle>Ashton — Portfolio</PageTitle>

<div class="home-layout">
    <div class="home-hero">
        <div class="hero-eyebrow">[ PORTFOLIO_v2.0 ]</div>
        <h1 class="hero-title">WELCOME, USER</h1>
        <p class="hero-subtitle">All you need to know about Ashton is here. Access granted.</p>
        <div class="hero-divider">
            <span class="divider-line"></span>
            <span class="divider-sigil">▓</span>
            <span class="divider-line"></span>
        </div>
        <p class="hero-body">
            Navigate through the archives using the sidebar.<br/>
            Each section holds a different chapter.<br/>
            We are watching.
        </p>
    </div>

    <div class="home-portrait">
        <div class="portrait-ring portrait-ring--outer"></div>
        <div class="portrait-ring portrait-ring--middle"></div>
        <div class="portrait-frame">
            <img src="images/Profile.jpg" alt="Portrait" />
        </div>
        <div class="portrait-scan"></div>
    </div>
</div>