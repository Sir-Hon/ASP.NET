@page "/education"
@attribute [StreamRendering]

<PageTitle>Education</PageTitle>

<div class="profile-wrap">
    <div class="section-label">[ EDUCATION_MODULE ]</div>
    <h1 class="page-title">ACADEMIC LOG</h1>

    <div class="edu-path-label">TRACING ACADEMIC PATH...</div>

    <!-- Elementary -->
    <div class="edu-stage-label">[ STAGE_01 :: ELEMENTARY ]</div>
    <div class="profile-grid-full">
        <div class="p-card">
            <div class="p-card-label">2012 — 2018</div>
            <div class="p-card-title">PRIMARY EDUCATION</div>
            <div class="p-card-body">
                <div class="timeline-place" style="margin-bottom:0.5rem;">Your Elementary School Name</div>
                Completed grades 1 through 6. Built a foundation in core subjects including
                Mathematics, English, Science, and Filipino. Active participant in school activities.
            </div>
            <span class="p-badge" style="margin-top:0.75rem;">COMPLETED</span>
        </div>
    </div>
    <div class="edu-stage-label">[ AWARDS :: ELEMENTARY ]</div>
    <div class="profile-grid-3">
        <div class="p-card">
            <div class="p-card-label">ACADEMIC</div>
            <div class="p-card-title">WITH HONORS</div>
            <div class="p-card-body">Graduated with honors. Consistently maintained high academic standing throughout primary education.</div>
        </div>
        <div class="p-card">
            <div class="p-card-label">SUBJECT AWARD</div>
            <div class="p-card-title">BEST IN MATH</div>
            <div class="p-card-body">Recognized for outstanding performance in Mathematics across multiple grade levels.</div>
        </div>
        <div class="p-card">
            <div class="p-card-label">PARTICIPATION</div>
            <div class="p-card-title">SCIENCE FAIR</div>
            <div class="p-card-body">Participated and placed in the school science fair. Demonstrated strong analytical thinking.</div>
        </div>
    </div>

    <!-- Junior High -->
    <div class="edu-stage-label">[ STAGE_02 :: JUNIOR HIGH SCHOOL ]</div>
    <div class="profile-grid-2">
        <div class="p-card">
            <div class="p-card-label">GRADE 7</div>
            <div class="p-card-title">FRESHMAN</div>
            <div class="p-card-body">
                <div class="timeline-place" style="margin-bottom:0.5rem;">Your High School Name</div>
                Introduction to secondary education. Core subjects plus TLE and MAPEH.
            </div>
            <span class="p-badge" style="margin-top:0.75rem;">COMPLETED</span>
        </div>
        <div class="p-card">
            <div class="p-card-label">GRADE 8</div>
            <div class="p-card-title">SOPHOMORE</div>
            <div class="p-card-body">
                <div class="timeline-place" style="margin-bottom:0.5rem;">Your High School Name</div>
                Deepened understanding of Sciences, Mathematics, and Humanities.
            </div>
            <span class="p-badge" style="margin-top:0.75rem;">COMPLETED</span>
        </div>
        <div class="p-card">
            <div class="p-card-label">GRADE 9</div>
            <div class="p-card-title">JUNIOR</div>
            <div class="p-card-body">
                <div class="timeline-place" style="margin-bottom:0.5rem;">Your High School Name</div>
                Advanced coursework in Sciences and Mathematics. Took on leadership roles in class.
            </div>
            <span class="p-badge" style="margin-top:0.75rem;">COMPLETED</span>
        </div>
        <div class="p-card">
            <div class="p-card-label">GRADE 10</div>
            <div class="p-card-title">SENIOR</div>
            <div class="p-card-body">
                <div class="timeline-place" style="margin-bottom:0.5rem;">Your High School Name</div>
                Completed Junior High School. Prepared for Senior High track selection.
            </div>
            <span class="p-badge" style="margin-top:0.75rem;">COMPLETED</span>
        </div>
    </div>
    <div class="edu-stage-label">[ AWARDS :: JUNIOR HIGH ]</div>
    <div class="profile-grid-3">
        <div class="p-card">
            <div class="p-card-label">ACADEMIC</div>
            <div class="p-card-title">TOP 10</div>
            <div class="p-card-body">Consistently ranked in the top 10 of the class during Junior High School.</div>
        </div>
        <div class="p-card">
            <div class="p-card-label">LEADERSHIP</div>
            <div class="p-card-title">CLASS OFFICER</div>
            <div class="p-card-body">Served as a class officer. Helped organize school events and represented the class in activities.</div>
        </div>
        <div class="p-card">
            <div class="p-card-label">COMPETITION</div>
            <div class="p-card-title">QUIZ BEE</div>
            <div class="p-card-body">Competed in the school-level quiz bee. Represented the class in Science and Mathematics categories.</div>
        </div>
    </div>

    <!-- Senior High -->
    <div class="edu-stage-label">[ STAGE_03 :: SENIOR HIGH SCHOOL ]</div>
    <div class="profile-grid-2">
        <div class="p-card">
            <div class="p-card-label">GRADE 11 — 2022</div>
            <div class="p-card-title">GRADE 11</div>
            <div class="p-card-body">
                <div class="timeline-place" style="margin-bottom:0.5rem;">Your Senior High School — ICT / STEM / HUMSS Track</div>
                First year of Senior High. Focused on track-specific subjects aligned with
                the chosen strand. Built technical and analytical skills.
            </div>
            <span class="p-badge" style="margin-top:0.75rem;">COMPLETED</span>
        </div>
        <div class="p-card">
            <div class="p-card-label">GRADE 12 — 2023</div>
            <div class="p-card-title">GRADE 12</div>
            <div class="p-card-body">
                <div class="timeline-place" style="margin-bottom:0.5rem;">Your Senior High School — ICT / STEM / HUMSS Track</div>
                Final year of Senior High. Completed immersion/work experience. Graduated and
                qualified for college admission.
            </div>
            <span class="p-badge" style="margin-top:0.75rem;">COMPLETED</span>
        </div>
    </div>
    <div class="edu-stage-label">[ AWARDS :: SENIOR HIGH ]</div>
    <div class="profile-grid-3">
        <div class="p-card">
            <div class="p-card-label">ACADEMIC</div>
            <div class="p-card-title">WITH HONORS</div>
            <div class="p-card-body">Graduated Senior High School with honors. Maintained high grades across all track subjects.</div>
        </div>
        <div class="p-card">
            <div class="p-card-label">IMMERSION</div>
            <div class="p-card-title">BEST TRAINEE</div>
            <div class="p-card-body">Recognized as best trainee during the work immersion program. Demonstrated professionalism and skill.</div>
        </div>
        <div class="p-card">
            <div class="p-card-label">EXTRACURRICULAR</div>
            <div class="p-card-title">PUBLICATION</div>
            <div class="p-card-body">Active member of the school publication. Contributed articles and assisted in layout design.</div>
        </div>
    </div>

    <!-- College -->
    <div class="edu-stage-label">[ STAGE_04 :: TERTIARY — ONGOING ]</div>
    <div class="profile-grid-3">
        <div class="p-card">
            <div class="p-card-label">2023 — 2024</div>
            <div class="p-card-title">1ST YEAR</div>
            <div class="p-card-body">
                <div class="timeline-place" style="margin-bottom:0.5rem;">Cebu Technological University</div>
                Started BS Information Technology. Core programming and IT fundamentals.
            </div>
            <span class="p-badge" style="margin-top:0.75rem;">COMPLETED</span>
        </div>
        <div class="p-card">
            <div class="p-card-label">2024 — 2025</div>
            <div class="p-card-title">2ND YEAR</div>
            <div class="p-card-body">
                <div class="timeline-place" style="margin-bottom:0.5rem;">Cebu Technological University</div>
                Web systems, data structures, and advanced programming. Building portfolio projects.
            </div>
            <span class="p-badge" style="margin-top:0.75rem; color:#00ff41; border-color:#00ff41;">IN PROGRESS</span>
        </div>
        <div class="p-card" style="opacity:0.4;">
            <div class="p-card-label">2025 — 2026</div>
            <div class="p-card-title">3RD YEAR</div>
            <div class="p-card-body">
                <div class="timeline-place" style="margin-bottom:0.5rem;">Cebu Technological University</div>
                Systems analysis, networks, and specialized electives. Coming soon.
            </div>
            <span class="p-badge" style="margin-top:0.75rem;">LOCKED</span>
        </div>
    </div>
    <div class="edu-stage-label">[ AWARDS :: COLLEGE ]</div>
    <div class="profile-grid-3">
        <div class="p-card">
            <div class="p-card-label">ACADEMIC</div>
            <div class="p-card-title">DEAN'S LIST</div>
            <div class="p-card-body">Included in the Dean's List for academic excellence during the first year of college.</div>
        </div>
        <div class="p-card">
            <div class="p-card-label">PROJECT</div>
            <div class="p-card-title">BEST IN IT</div>
            <div class="p-card-body">Recognized for outstanding project output in an IT subject. Demonstrated strong technical skills.</div>
        </div>
        <div class="p-card">
            <div class="p-card-label">ORGANIZATION</div>
            <div class="p-card-title">THE MODERN FISHER</div>
            <div class="p-card-body">Active layout editor for the official campus publication of CTU Daanbantayan.</div>
        </div>
    </div>
</div>